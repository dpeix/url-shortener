<div class="card shadow-sm" data-url-id="{{ url.id }}">
    <div class="card-body">
        <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap">
            <div class="flex-grow-1 min-w-0">
                <div class="d-flex align-items-center gap-2 mb-1">
                    <a href="{{ path('app_redirect', { shortCode: url.shortCode }) }}"
                       class="fw-bold text-dark text-decoration-none"
                       target="_blank">
                        /{{ url.shortCode }}
                    </a>
                    {% if not url.isActive %}
                        <span class="badge bg-secondary">Inactif</span>
                    {% elseif url.expiresAt is not null and url.expiresAt < date() %}
                        <span class="badge bg-warning text-dark">Expiré</span>
                    {% else %}
                        <span class="badge bg-success">Actif</span>
                    {% endif %}
                </div>
                <div class="text-muted small text-truncate" style="max-width: 400px" title="{{ url.originalUrl }}">
                    {{ url.originalUrl }}
                </div>
                <div class="d-flex gap-3 mt-2 text-muted" style="font-size: .8rem">
                    <span>{{ url.clickCount }} clic{{ url.clickCount > 1 ? 's' }}</span>
                    <span>Créé le {{ url.createdAt|date('d/m/Y à H:i') }}</span>
                    {% if url.expiresAt is not null %}
                        <span>Expire le {{ url.expiresAt|date('d/m/Y') }}</span>
                    {% endif %}
                </div>
            </div>
            <button
                type="button"
                class="btn btn-outline-secondary btn-sm"
                data-action="click->url-list#copy"
                data-short-code="{{ url.shortCode }}"
                title="Copier le lien"
            >
                📋
            </button>
        </div>
    </div>
</div>
